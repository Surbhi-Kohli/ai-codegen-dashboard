# Database — SQLite by default (zero setup, no server needed)
DATABASE_URL=sqlite+aiosqlite:///./ai_dashboard.db
# For DDI MySQL:  DATABASE_URL=mysql+aiomysql://root:@localhost:3306/ai_dashboard
# For Postgres:   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_dashboard

# Jira
JIRA_BASE_URL=https://cisco-sbg.atlassian.net
JIRA_EMAIL=your-email@cisco.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEYS=ZTAEX,ZTCE
JIRA_POLL_INTERVAL_MINUTES=15

# GitHub
GITHUB_TOKEN=your-github-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_ORG=cisco-sbg
GITHUB_REPOS=ZT-trustedpath

# git-ai
GITAI_WEBHOOK_SECRET=your-gitai-secret

# Webex (stretch)
WEBEX_BOT_TOKEN=your-webex-bot-token
WEBEX_WEBHOOK_SECRET=your-webex-secret
WEBEX_REVIEW_ROOM_ID=your-room-id
